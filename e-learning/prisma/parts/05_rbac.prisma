model Permission {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  group       String?
  createdAt   DateTime @default(now())

  roles RolePermission[]

  @@map("permission")
}

model RolePermission {
  id           String @id @default(cuid())
  role         Role
  permissionId String

  permission Permission @relation(fields: [permissionId], references: [id])

  @@unique([role, permissionId])
  @@map("role_permission")
}
