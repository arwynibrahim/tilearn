generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  LEARNER
  CREATOR
  MANAGER
  ADMIN
  SUPER_ADMIN
}

enum ContextType {
  INDIVIDUAL
  ORGANIZATION
  PLATFORM
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  EXPIRED
  DROPPED
}

enum ModuleType {
  VIDEO
  VR
  QUIZ
  TEXT
}

enum QuestionType {
  QCM
  VRAI_FAUX
  DRAG_DROP
  ORDER
}

enum PaymentProvider {
  CINETPAY
  STRIPE
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum PaymentMethod {
  ORANGE_MONEY
  MOOV_MONEY
  CARD
}

enum SubscriptionPlan {
  FREEMIUM
  STARTER
  PRO
  EXPERT
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED
}

enum LicensePlan {
  STARTER_10
  PRO_30
  PREMIUM_50
  ENTERPRISE_100
  UNLIMITED
}

enum OrganizationType {
  UNIVERSITY
  COMPANY
  HOSPITAL
  NGO
  GOV
}

enum VRHeadsetModel {
  META_QUEST_2
  META_QUEST_3
  PICO_4
}

enum VRHeadsetStatus {
  ONLINE
  OFFLINE
  CHARGING
  IN_USE
  MAINTENANCE
  LOST
}

enum InteractionType {
  CLICK
  GRAB
  LOOK_AT
  COLLISION
}

enum CourseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

model Permission {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  group       String?
  createdAt   DateTime @default(now())

  roles RolePermission[]

  @@map("permission")
}

model RolePermission {
  id           String @id @default(cuid())
  role         Role
  permissionId String

  permission Permission @relation(fields: [permissionId], references: [id])

  @@unique([role, permissionId])
  @@map("role_permission")
}

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  passwordHash     String
  nom              String
  prenom           String
  telephone        String?
  avatar           String?
  emailVerifiedAt  DateTime?
  interests        String[]
  lastLoginAt      DateTime?
  deletedAt        DateTime?
  resetToken       String?
  resetTokenExpiresAt DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  enrollments         Enrollment[]
  certificates        Certificate[]
  payments            Payment[]
  progresses          Progress[]
  licenseAssignments  LicenseAssignment[]
  subscriptions       Subscription[]
  reviews             CourseReview[]
  instructorProfile   InstructorProfile?
  vrHeadset           VRHeadset[]
  coursesCreated      Course[]             @relation("CourseCreator")
  quizAttempts        QuizAttempt[]
  memberships         Membership[]
}

model Membership {
  id          String      @id @default(cuid())
  userId      String
  contextType ContextType
  contextId   String?
  role        Role
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user        User        @relation(fields: [userId], references: [id])

  @@unique([userId, contextType, contextId])
  @@map("membership")
}

model InstructorProfile {
  id             String  @id @default(cuid())
  userId         String  @unique
  bio            String?
  expertiseAreas String[]
  totalStudents  Int     @default(0)
  totalRevenue   Float   @default(0)
  rating         Float   @default(0)
  isVerified     Boolean @default(false)
  bankAccountInfo String?
  taxId          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model Course {
  id          String     @id @default(cuid())
  title       String
  slug        String     @unique
  description String?
  thumbnail   String?
  domainId    String
  level       CourseLevel @default(BEGINNER)
  duration    Int?
  language    String     @default("fr")
  price       Float?
  isPublished Boolean   @default(false)
  createdBy   String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  domain      Domain     @relation(fields: [domainId], references: [id])
  creator     User       @relation("CourseCreator", fields: [createdBy], references: [id])
  modules     Module[]
  enrollments Enrollment[]
  certificates Certificate[]
  reviews     CourseReview[]
  learningPathCourses LearningPathCourse[]
}

model Domain {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  icon        String?
  description String?
  courses     Course[]
}

model Module {
  id              String     @id @default(cuid())
  courseId        String
  title           String
  type            ModuleType
  order           Int
  contentUrl      String?
  durationSeconds Int?
  isRequired      Boolean    @default(true)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  course     Course      @relation(fields: [courseId], references: [id])
  vrScene    VRScene?
  quizzes    Quiz[]
  progresses Progress[]
}

model VRScene {
  id            String   @id @default(cuid())
  moduleId      String   @unique
  title         String
  sceneData     Json?
  interactions  Json?
  branches      Json?
  fallback360Url String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  module Module @relation(fields: [moduleId], references: [id])
}

model Enrollment {
  id          String           @id @default(cuid())
  userId      String
  courseId    String
  status      EnrollmentStatus @default(ACTIVE)
  enrolledAt  DateTime         @default(now())
  completedAt DateTime?
  expiryDate  DateTime?

  user   User   @relation(fields: [userId], references: [id])
  course Course @relation(fields: [courseId], references: [id])
}

model Progress {
  id               String   @id @default(cuid())
  userId           String
  moduleId         String
  status           String   @default("NOT_STARTED")
  score            Float?
  timeSpentSeconds Int?
  lastPosition     String?
  startedAt        DateTime?
  completedAt      DateTime?

  user   User   @relation(fields: [userId], references: [id])
  module Module @relation(fields: [moduleId], references: [id])

  @@unique([userId, moduleId])
}

model Quiz {
  id             String   @id @default(cuid())
  moduleId       String
  title          String
  passingScore   Float?
  maxAttempts    Int?     @default(3)
  shuffleQuestions Boolean @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  module         Module         @relation(fields: [moduleId], references: [id])
  questions      Question[]
  attempts       QuizAttempt[]
}

model Question {
  id            String       @id @default(cuid())
  quizId        String
  text          String
  type          QuestionType
  options       Json?
  correctAnswer String?
  points        Float?       @default(1)
  explanation   String?
  order         Int?         @default(0)

  quiz Quiz @relation(fields: [quizId], references: [id])
}

model QuizAttempt {
  id          String   @id @default(cuid())
  userId      String
  quizId      String
  score       Float?
  answers     Json?
  startedAt   DateTime?
  completedAt DateTime?
  passed      Boolean?

  user User @relation(fields: [userId], references: [id])
  quiz Quiz @relation(fields: [quizId], references: [id])
}

model Certificate {
  id               String    @id @default(cuid())
  userId           String
  courseId         String
  templateId       String?
  certificateUid   String    @unique
  issuedAt         DateTime  @default(now())
  qrCodeHash       String?
  verificationUrl  String?
  revokedAt        DateTime?

  user   User   @relation(fields: [userId], references: [id])
  course Course @relation(fields: [courseId], references: [id])
}

model Payment {
  id              String          @id @default(cuid())
  userId          String
  transactionId   String          @unique
  amount          Float
  currency        String          @default("XOF")
  provider        PaymentProvider
  status          PaymentStatus   @default(PENDING)
  paymentMethod   PaymentMethod?
  subscriptionId  String?
  invoiceUrl      String?
  providerReference String?       @map("provider_reference")
  paidAt          DateTime?
  refundedAt      DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  user         User         @relation(fields: [userId], references: [id])
  subscription Subscription? @relation(fields: [subscriptionId], references: [id])
  invoice      Invoice?

  @@map("payment")
}

model Subscription {
  id                 String             @id @default(cuid())
  userId             String
  plan               SubscriptionPlan
  status             SubscriptionStatus @default(ACTIVE)
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  canceledAt         DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  user     User      @relation(fields: [userId], references: [id])
  payments Payment[]
}

model Invoice {
  id             String   @id @default(cuid())
  subscriptionId String?
  paymentId      String   @unique
  number         String   @unique
  total          Float
  tax            Float?
  pdfUrl         String?
  createdAt      DateTime @default(now())

  payment Payment @relation(fields: [paymentId], references: [id])
}

model Organization {
  id           String           @id @default(cuid())
  name         String
  type         OrganizationType
  emailDomain  String?
  logo         String?
  address      String?
  country      String?
  phone        String?
  contractStart DateTime?
  contractEnd  DateTime?
  isActive     Boolean          @default(true)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  licenses       License[]
  learningPaths  LearningPath[]
  vrHeadsets     VRHeadset[]
  chargingStations ChargingStation[]
}

model License {
  id             String      @id @default(cuid())
  organizationId String
  plan           LicensePlan
  quantity       Int
  usedCount      Int         @default(0)
  startDate      DateTime
  endDate        DateTime
  price          Float?
  autoRenew      Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  organization Organization          @relation(fields: [organizationId], references: [id])
  assignments  LicenseAssignment[]
}

model LicenseAssignment {
  id           String    @id @default(cuid())
  licenseId    String
  userId       String
  assignedBy   String?
  assignedAt   DateTime  @default(now())
  revokedAt    DateTime?

  license License @relation(fields: [licenseId], references: [id])
  user    User    @relation(fields: [userId], references: [id])
}

model LearningPath {
  id             String   @id @default(cuid())
  organizationId String
  title          String
  description    String?
  isMandatory    Boolean  @default(false)
  createdBy      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization         @relation(fields: [organizationId], references: [id])
  courses      LearningPathCourse[]
}

model LearningPathCourse {
  id        String @id @default(cuid())
  pathId    String
  courseId  String
  order     Int

  path   LearningPath @relation(fields: [pathId], references: [id])
  course Course       @relation(fields: [courseId], references: [id])
}

model VRHeadset {
  id              String           @id @default(cuid())
  organizationId  String
  serialNumber    String           @unique
  model           VRHeadsetModel
  firmwareVersion String?
  status          VRHeadsetStatus  @default(OFFLINE)
  batteryLevel    Int?
  lastPing        DateTime?
  assignedUserId  String?
  kioskModeEnabled Boolean         @default(false)
  purchaseDate    DateTime?
  warrantyUntil   DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  organization  Organization @relation(fields: [organizationId], references: [id])
  assignedUser  User?        @relation(fields: [assignedUserId], references: [id])
}

model ChargingStation {
  id             String @id @default(cuid())
  organizationId String
  model          String?
  portsTotal     Int
  portsAvailable Int
  location       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
}

model CourseReview {
  id        String   @id @default(cuid())
  courseId  String
  userId    String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  course Course @relation(fields: [courseId], references: [id])
  user   User   @relation(fields: [userId], references: [id])
}
