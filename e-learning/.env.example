# Database
DATABASE_URL="postgresql://til_user:til_password@localhost:5432/til_db?schema=public"

# JWT (RS256 — générer avec openssl genrsa -out private.key 2048)
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
JWT_ACCESS_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="7d"

# Redis (OPTIONNEL — uniquement pour le rate-limiting distribué / multi-instances)
# Si REDIS_URL est absent, le throttler utilise la mémoire locale (aucun Redis requis).
# Upstash : utiliser l'URL TLS `rediss://default:<password>@<region>.upstash.io:6379`
# REDIS_URL="rediss://default:xxxxx@eu2-xxx.upstash.io:6379"
REDIS_HOST="localhost"
REDIS_PORT=6379

# AWS
AWS_REGION="af-south-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
S3_BUCKET="til-assets"
CLOUDFRONT_DOMAIN=""

# Payment — LigdiCash (Mobile Money)
LIGDICASH_API_KEY=""
LIGDICASH_API_TOKEN=""
LIGDICASH_STORE_NAME="Total Innovation Learning"
LIGDICASH_STORE_WEBSITE="https://tilearning.net"
LIGDICASH_RETURN_URL="https://tilearning.net/payment/success"
LIGDICASH_CANCEL_URL="https://tilearning.net/payment/cancel"
LIGDICASH_CALLBACK_URL="https://api.tilearning.net/api/v1/payments/ligdicash/callback"

# Payment — Stripe (carte bancaire)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
LINKEDIN_CLIENT_ID=""
LINKEDIN_CLIENT_SECRET=""

# Email — Provider HTTP Resend (recommandé en prod : pas de souci SMTP/IPv6 sur Railway)
# Si RESEND_API_KEY est défini, il est utilisé en priorité ; sinon repli sur le SMTP ci-dessous.
# Créer une clé sur https://resend.com/api-keys et vérifier le domaine (DNS) pour l'expéditeur.
# RESEND_API_KEY="re_xxxxxxxx"

# Email (SMTP) — exemple Hostinger (SSL sur le port 465, recommandé)
# Créer d'abord une boîte mail dans hPanel → Emails, puis utiliser ses identifiants.
# SMTP_USER doit être l'adresse complète ; SMTP_FROM doit utiliser le MÊME domaine.
SMTP_HOST="smtp.hostinger.com"
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER="noreply@tondomaine.com"
SMTP_PASS=""
SMTP_FROM="Total Innovation Learning <noreply@tondomaine.com>"
# Alternative STARTTLS : SMTP_PORT=587 et SMTP_SECURE=false

# App
PORT=3000
NODE_ENV="development"
FRONTEND_URL="http://localhost:3001"
API_PREFIX="api/v1"
